{
  "name": "sanity-log-analyzer",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "sanity-log-analyzer": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "open": "^10.1.0",
    "ua-parser-js": "^2.0.10"
  },
  "scripts": {
    "build:core": "tsc && find dist -name '*.test.*' -delete",
    "build:report": "vite build",
    "build:tests": "tsc -p tsconfig.tests.json",
    "build": "npm run build:core && npm run build:report",
    "prepublishOnly": "npm run build",
    "analyze": "npm run build && node dist/cli.js",
    "preview:report": "vite --config vite.preview.config.ts",
    "test": "npm run build:core && npm run build:tests && npm run build:report && node --test 'dist/**/*.test.js'"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@sanity/prism-groq": "^1.1.2",
    "@types/node": "24",
    "@types/prismjs": "^1.26.6",
    "groq-js": "^1.30.3",
    "preact": "^10.29.5",
    "preact-render-to-string": "^6.7.0",
    "prismjs": "^1.30.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.3"
  }
}
