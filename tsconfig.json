{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"types": ["node"],
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/report/**/*.tsx",
		"src/report/**/*.css",
		"src/report/preview",
		"src/report/components",
		"src/report/utils",
		"src/report/fixtures",
		"src/report/scripts",
		"src/report/highlight-groq.ts",
		"src/report/sections.ts",
		"src/report/vertical-bar-chart.ts",
		"src/report/styles/collect-css.ts"
	]
}
